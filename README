## 🐳📦 Running with Docker

```yaml
# docker-compose.yml 🐳
version: '3.8'
services:

  app: 🚀
    build: .
    ports:
      - "8080:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=prod
      - DATABASE_URL=jdbc:postgresql://postgres:5432/student_fee_db
    depends_on:
      - postgres
      - redis

  postgres: 🐘
    image: postgres:15
    environment:
      POSTGRES_DB: student_fee_db
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: yourpassword
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

  redis: 🔴
    image: redis:7-alpine
    command: redis-server --requirepass yourredispassword
    ports:
      - "6379:6379"

volumes:
  postgres_data: 💾
```

```bash
# 🔨 Build and start all services
docker-compose up --build

# 🌙 Run in background
docker-compose up -d

# 🛑 Stop all services
docker-compose down
```

